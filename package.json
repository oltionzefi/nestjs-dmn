{
  "name": "@oltionzefi/nestjs-dmn",
  "version": "0.1.0",
  "description": "Lightweight DMN 1.3 parser and evaluator for NestJS — built on dmn-moddle and feelin.",
  "license": "MIT",
  "author": {
    "name": "Oltion Zefi",
    "email": "oltion@oltionzefi.com",
    "url": "https://oltionzefi.com"
  },
  "homepage": "https://github.com/oltionzefi/nestjs-dmn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oltionzefi/nestjs-dmn.git"
  },
  "bugs": {
    "url": "https://github.com/oltionzefi/nestjs-dmn/issues"
  },
  "keywords": [
    "nestjs",
    "dmn",
    "dmn-1.3",
    "decision-table",
    "feel",
    "rules-engine",
    "business-rules"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@9.15.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "reflect-metadata": "^0.2"
  },
  "dependencies": {
    "dmn-moddle": "^12.0.0",
    "feelin": "^0.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.0.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
